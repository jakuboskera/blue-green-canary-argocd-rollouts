{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["renovate", "dependencies"],
  "packageRules": [
    {
      "description": "Auto-merge minor and patch Helm chart dependency updates",
      "matchManagers": ["helmv2"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Auto-merge minor and patch Terraform provider updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
